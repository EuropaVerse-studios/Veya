// Programma di esempio in Veya
// Dimostra: variabili, if/else, for, while, mut, funzioni

function main():
    name = "Gabry"
    x = 42

    if x > 10:
        print("Grande!")
    else:
        print("Piccolo")

    for i in 0..5:
        print(i)

    mut count = 10
    while count > 0:
        count -= 1
